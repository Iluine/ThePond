# ─── Rust / Cargo ────────────────────────────────────────────────
debug/
target/
**/*.rs.bk
*.pdb
**/mutants.out*/

# ─── Node / Vite ─────────────────────────────────────────────────
node_modules/
dist/
dist-ssr/
*.local
.vite/
# Caddyfile.local est notre config dev versionnée, pas un fichier local Vite.
!Caddyfile.local

# ─── SQLite (database files & WAL artifacts) ─────────────────────
*.db
*.db-journal
*.db-shm
*.db-wal
*.sqlite
*.sqlite3

# ─── Uploads (runtime data, never committed) ─────────────────────
uploads/

# ─── Environment / secrets ───────────────────────────────────────
.env
.env.local
.env.*.local

# ─── IDE / editors ───────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo

# ─── OS noise ────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ─── Logs ────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ─── Caddy (local dev artifacts) ─────────────────────────────────
caddy_data/
caddy_config/

# ─── Playwright (screenshots, traces, MCP outputs) ───────────────
.playwright-mcp/
test-results/
playwright-report/
