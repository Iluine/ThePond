# Variables attendues par docker-compose.yml.
# Copie ce fichier en .env (jamais committé) puis remplis les valeurs.

# ─── Caddy / DNS-01 DuckDNS ──────────────────────────────────────
POND_DOMAIN=mariage.duckdns.org
DUCKDNS_TOKEN=replace-me

# ─── Backend secrets ─────────────────────────────────────────────
# Token HMAC partagé pour tous les témoins. Régénéré à chaque rotation.
# Génère-le par exemple avec : openssl rand -hex 32
WITNESS_SECRET=replace-me-with-a-strong-random-secret

# ─── Volumes (défaut Synology) ───────────────────────────────────
POND_DATA_DIR=/volume1/docker/thepond

# ─── Logs ────────────────────────────────────────────────────────
RUST_LOG=info,sqlx=warn
